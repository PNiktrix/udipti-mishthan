<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us – Udipti Mishthan</title>
  <link rel="stylesheet" href="../CSS/main.css" />
  <link rel="stylesheet" href="../CSS/components.css" />
  <link rel="stylesheet" href="../CSS/responsive.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>

  <!-- HEADER -->
  <header class="site-header" id="siteHeader">
    <div class="header-top">
      <span><i class="fas fa-phone-alt"></i> +91 86551 67770</span>
      <span><i class="fas fa-clock"></i> Mon–Sun: 8:00 AM – 9:00 PM</span>
      <span><i class="fas fa-map-marker-alt"></i> Mumbai, Maharashtra</span>
    </div>
    <nav class="navbar container">
      <a href="../index.html" class="logo">
        <img src="../anik/images/logo.png" alt="Udipti Mishthan" onerror="this.style.display='none';document.getElementById('logoText').style.display='block'" />
        <span id="logoText" class="logo-text" style="display:none;">🍬 Udipti Mishthan</span>
      </a>
      <ul class="nav-links" id="navLinks">
        <li><a href="../index.html">Home</a></li>
        <li><a href="../index.html#products">Sweets</a></li>
        <li><a href="festival.html">Festival</a></li>
        <li><a href="../gallery.html">Gallery</a></li>
        <li><a href="about.html">About</a></li>
        <li><a href="contact.html" class="active">Contact</a></li>
      </ul>
      <div class="nav-actions">
        <button class="icon-btn" id="wishlistBtn" aria-label="Wishlist">
          <i class="fas fa-heart"></i>
          <span class="badge" id="wishlistCount">0</span>
        </button>
        <button class="icon-btn" id="cartBtn" aria-label="Cart">
          <i class="fas fa-shopping-bag"></i>
          <span class="badge" id="cartCount">0</span>
        </button>
        <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      </div>
    </nav>
  </header>

  <!-- Cart / Wishlist sidebars -->
  <div class="cart-overlay" id="cartOverlay"></div>
  <aside class="cart-sidebar" id="cartSidebar">
    <div class="cart-header">
      <h3><i class="fas fa-shopping-bag"></i> Your Cart</h3>
      <button id="cartClose"><i class="fas fa-times"></i></button>
    </div>
    <div class="cart-items" id="cartItems"></div>
    <div class="cart-footer" id="cartFooter" style="display:none;">
      <div class="cart-total"><span>Total:</span><strong id="cartTotal">₹0</strong></div>
      <button class="btn btn-whatsapp btn-block" id="whatsappOrder">
        <i class="fab fa-whatsapp"></i> Order via WhatsApp
      </button>
    </div>
  </aside>
  <div class="wishlist-overlay" id="wishlistOverlay"></div>
  <aside class="wishlist-sidebar" id="wishlistSidebar">
    <div class="cart-header">
      <h3><i class="fas fa-heart"></i> Wishlist</h3>
      <button id="wishlistClose"><i class="fas fa-times"></i></button>
    </div>
    <div class="wishlist-items" id="wishlistItems"></div>
  </aside>

  <!-- PAGE HERO -->
  <section class="page-hero" style="background-image:url('../anik/images/contact-banner.jpg')">
    <div class="page-hero-overlay">
      <div class="container">
        <nav class="breadcrumb">
          <a href="../index.html">Home</a> <i class="fas fa-chevron-right"></i> <span>Contact</span>
        </nav>
        <h1>Get in Touch</h1>
        <p>We'd love to hear from you — order, bulk enquiry or just say hi!</p>
      </div>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="section contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- Contact Info Cards -->
        <div class="contact-info">
          <div class="contact-card">
            <div class="contact-card-icon"><i class="fas fa-phone-alt"></i></div>
            <h4>Call Us</h4>
            <p>For orders and enquiries</p>
            <a href="tel:+918655167770" class="contact-link">+91 86551 67770</a>
          </div>
          <div class="contact-card">
            <div class="contact-card-icon whatsapp-bg"><i class="fab fa-whatsapp"></i></div>
            <h4>WhatsApp Order</h4>
            <p>Fastest way to place your order</p>
            <a href="https://wa.me/918655167770" target="_blank" class="btn btn-whatsapp btn-sm">
              <i class="fab fa-whatsapp"></i> Chat on WhatsApp
            </a>
          </div>
          <div class="contact-card">
            <div class="contact-card-icon"><i class="fas fa-envelope"></i></div>
            <h4>Email Us</h4>
            <p>For bulk &amp; corporate orders</p>
            <a href="mailto:udiptimishthan@gmail.com" class="contact-link">udiptimishthan@gmail.com</a>
          </div>
          <div class="contact-card">
            <div class="contact-card-icon"><i class="fas fa-map-marker-alt"></i></div>
            <h4>Visit Our Shop</h4>
            <p>Mumbai, Maharashtra, India</p>
            <a href="https://maps.google.com/?q=Udipti+Mishthan+Mumbai" target="_blank" class="contact-link">
              Get Directions <i class="fas fa-external-link-alt"></i>
            </a>
          </div>
          <div class="contact-card hours-card">
            <div class="contact-card-icon"><i class="fas fa-clock"></i></div>
            <h4>Opening Hours</h4>
            <table class="hours-table">
              <tr><td>Monday – Friday</td><td><strong>8:00 AM – 9:00 PM</strong></td></tr>
              <tr><td>Saturday</td><td><strong>8:00 AM – 9:30 PM</strong></td></tr>
              <tr><td>Sunday</td><td><strong>9:00 AM – 8:00 PM</strong></td></tr>
              <tr class="highlight-row"><td colspan="2"><i class="fas fa-info-circle"></i> Extended hours during festivals</td></tr>
            </table>
          </div>
        </div>

        <!-- Enquiry Form -->
        <div class="contact-form-wrap">
          <h2>Send an Enquiry</h2>
          <p>Fill in the form below and we'll get back to you shortly, or order directly on WhatsApp for fastest response.</p>
          <div class="contact-form" id="contactForm">
            <div class="form-row">
              <div class="form-group">
                <label for="contactName">Full Name *</label>
                <input type="text" id="contactName" placeholder="Your name" required />
              </div>
              <div class="form-group">
                <label for="contactPhone">Phone / WhatsApp *</label>
                <input type="tel" id="contactPhone" placeholder="+91 XXXXX XXXXX" required />
              </div>
            </div>
            <div class="form-group">
              <label for="contactEmail">Email Address</label>
              <input type="email" id="contactEmail" placeholder="your@email.com" />
            </div>
            <div class="form-group">
              <label for="contactSubject">Subject</label>
              <select id="contactSubject">
                <option value="">Select a topic…</option>
                <option value="order">Place an Order</option>
                <option value="bulk">Bulk / Party Order</option>
                <option value="corporate">Corporate Gift Boxes</option>
                <option value="custom">Custom Sweet Enquiry</option>
                <option value="feedback">Feedback / Review</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="contactMsg">Message *</label>
              <textarea id="contactMsg" rows="5" placeholder="Tell us what you need — sweet type, quantity, delivery date…" required></textarea>
            </div>
            <div class="form-actions">
              <button type="button" class="btn btn-primary btn-lg" id="sendEnquiryBtn">
                <i class="fas fa-paper-plane"></i> Send Enquiry
              </button>
              <button type="button" class="btn btn-whatsapp btn-lg" id="sendWhatsAppEnquiry">
                <i class="fab fa-whatsapp"></i> Send via WhatsApp
              </button>
            </div>
            <div class="form-success" id="formSuccess" style="display:none;">
              <i class="fas fa-check-circle"></i>
              <p>Thank you! We'll get back to you shortly.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GOOGLE MAP -->
  <section class="map-section">
    <div class="map-header container">
      <h2>Find Us</h2>
      <p>Visit our shop in Mumbai for the freshest handmade sweets</p>
    </div>
    <div class="map-embed">
      <!-- Embedded Google Map — Mumbai placeholder. Replace src with your exact location embed URL -->
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d241316.6753641938!2d72.71637185!3d19.0821978!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be7c6306644edc1%3A0x5da4ed8f8d648c69!2sMumbai%2C%20Maharashtra!5e0!3m2!1sen!2sin!4v1712345678901!5m2!1sen!2sin"
        width="100%" height="400" style="border:0;" allowfullscreen="" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade" title="Udipti Mishthan Location">
      </iframe>
    </div>
  </section>

  <!-- WHATSAPP FLOAT -->
  <a href="https://wa.me/918655167770" target="_blank" class="whatsapp-float"><i class="fab fa-whatsapp"></i></a>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-top container">
      <div class="footer-col">
        <span class="logo-text">🍬 Udipti Mishthan</span>
        <p>Pure Taste, Healthy Sweetness. Handcrafted Indian sweets.</p>
      </div>
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="../index.html">Home</a></li>
          <li><a href="../index.html#products">Sweets</a></li>
          <li><a href="festival.html">Festival Specials</a></li>
          <li><a href="../gallery.html">Gallery</a></li>
          <li><a href="about.html">About Us</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <ul class="contact-list">
          <li><i class="fas fa-phone-alt"></i> <a href="tel:+918655167770">+91 86551 67770</a></li>
          <li><i class="fab fa-whatsapp"></i> <a href="https://wa.me/918655167770">WhatsApp</a></li>
          <li><i class="fas fa-map-marker-alt"></i> Mumbai, Maharashtra</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© <span id="footerYear"></span> Udipti Mishthan. Made with <i class="fas fa-heart"></i> in Mumbai.</p>
    </div>
  </footer>

  <script src="../anik/config.js"></script>
  <script src="../anik/cart.js"></script>
  <script src="../anik/wishlist.js"></script>
  <script src="../anik/order.js"></script>
  <script src="../anik/app.js"></script>
  <script>
    document.getElementById('footerYear').textContent = new Date().getFullYear();
    document.getElementById('hamburger').addEventListener('click', () => {
      document.getElementById('navLinks').classList.toggle('open');
    });

    // Sidebars
    ['cart','wishlist'].forEach(type => {
      document.getElementById(type+'Btn').addEventListener('click', () => {
        document.getElementById(type+'Sidebar').classList.add('open');
        document.getElementById(type+'Overlay').classList.add('open');
      });
      document.getElementById(type+'Close').addEventListener('click', () => {
        document.getElementById(type+'Sidebar').classList.remove('open');
        document.getElementById(type+'Overlay').classList.remove('open');
      });
      document.getElementById(type+'Overlay').addEventListener('click', () => {
        document.getElementById(type+'Sidebar').classList.remove('open');
        document.getElementById(type+'Overlay').classList.remove('open');
      });
    });

    // Send via WhatsApp form
    document.getElementById('sendWhatsAppEnquiry').addEventListener('click', () => {
      const name    = document.getElementById('contactName').value.trim();
      const phone   = document.getElementById('contactPhone').value.trim();
      const subject = document.getElementById('contactSubject').value;
      const msg     = document.getElementById('contactMsg').value.trim();
      if (!name || !phone || !msg) { alert('Please fill in Name, Phone and Message.'); return; }
      const wa = `Hello Udipti Mishthan!\n\n👤 Name: ${name}\n📞 Phone: ${phone}\n📋 Subject: ${subject || 'General'}\n\n💬 Message:\n${msg}`;
      window.open('https://wa.me/918655167770?text=' + encodeURIComponent(wa), '_blank');
    });

    // Send enquiry (simulate — no backend)
    document.getElementById('sendEnquiryBtn').addEventListener('click', () => {
      const name = document.getElementById('contactName').value.trim();
      const msg  = document.getElementById('contactMsg').value.trim();
      if (!name || !msg) { alert('Please fill in Name and Message.'); return; }
      document.getElementById('contactForm').style.opacity = '0.5';
      setTimeout(() => {
        document.getElementById('contactForm').style.opacity = '1';
        document.getElementById('formSuccess').style.display = 'flex';
        document.getElementById('contactName').value = '';
        document.getElementById('contactPhone').value = '';
        document.getElementById('contactEmail').value = '';
        document.getElementById('contactMsg').value = '';
        setTimeout(() => document.getElementById('formSuccess').style.display = 'none', 5000);
      }, 800);
    });
  </script>
</body>
</html>
